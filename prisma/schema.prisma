generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candidate {
  id            String          @id
  clerkUserId   String          @unique // vinculado ao usuário Clerk
  name          String
  cityId        String
  slug          String          @unique
  plan          String          @default("candidato") // "candidato" | "campanha" | "partido"
  planExpiresAt DateTime?
  createdAt     DateTime        @default(now())
  City          City            @relation(fields: [cityId], references: [id])
  CitizenDemand CitizenDemand[]
}

model CitizenDemand {
  id             String       @id
  candidateId    String
  neighborhoodId String
  title          String
  description    String
  category       String
  sentiment      String
  latitude       Float
  longitude      Float
  status         String       @default("PENDENTE")
  createdAt      DateTime     @default(now())
  Candidate      Candidate    @relation(fields: [candidateId], references: [id])
  Neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])
}

model City {
  id           String         @id
  name         String
  state        String
  ibgeCode     String         @unique
  latitude     Float
  longitude    Float
  Candidate    Candidate[]
  CrimeOccurrences CrimeOccurrence[]
  Neighborhood Neighborhood[]
}

model ElectoralResult {
  id             String       @id
  neighborhoodId String
  year           Int
  candidateName  String?
  votesCount     Int
  Neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])
}

model Neighborhood {
  id                 String               @id
  name               String
  cityId             String
  totalVoters        Int?                 // null = dado não disponível
  averageIncome      Float?
  leisureAreasCount  Int?
  securityIncidents  Int?
  sanitationCoverage Float?
  transportLines     Int?
  CitizenDemand      CitizenDemand[]
  ElectoralResult    ElectoralResult[]
  ElectionProjection ElectionProjection[]
  City               City                 @relation(fields: [cityId], references: [id])
  Metrics            NeighborhoodMetric[]
  HealthFacilities   HealthFacility[]
  LeisureAreas       LeisureArea[]
  CrimeOccurrences   CrimeOccurrence[]
}

model LeisureArea {
  id             String       @id @default(uuid())
  name           String
  type           String       // "PRACA" | "PARQUE"
  street         String?
  neighborhoodId String
  Neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])
}

model ElectionProjection {
  id             String       @id @default(uuid())
  neighborhoodId String
  year           Int          @default(2022)
  position       String
  candidateName  String
  projectedVotes Int
  confidence     Float?
  Neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])
}

model NeighborhoodMetric {
  id             String       @id @default(uuid())
  neighborhoodId String
  year           Int
  month          Int?
  metricType     String
  value          Float
  Neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])
}

model HealthFacility {
  id               String       @id @default(uuid())
  neighborhoodId   String
  name             String
  type             String
  latitude         Float
  longitude        Float
  currentQueueSize Int?
  averageWaitTime  Int?
  Neighborhood     Neighborhood @relation(fields: [neighborhoodId], references: [id])
}

model CrimeOccurrence {
  id             String       @id @default(uuid())
  neighborhoodId String
  cityId         String
  year           Int
  month          Int          // 1-12
  crimeType      String       // "ROUBO" | "FURTO" | "HOMICIDIO" | "TRAFICO" | "LESAO" | "ESTUPRO" | "OUTROS"
  count          Int
  source         String       @default("SSP-MG")
  createdAt      DateTime     @default(now())
  Neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])
  City           City         @relation(fields: [cityId], references: [id])

  @@unique([neighborhoodId, year, month, crimeType])
  @@index([neighborhoodId, year, month])
  @@index([cityId, year, month])
}

// ── Dados TSE importados dos CSVs ─────────────────────────────────────────────

model TseCandidato {
  id               String @id @default(uuid())
  ano              Int
  sequencial       String
  numero           String
  nome             String
  nomeUrna         String
  numeroPartido    String
  siglaPartido     String
  cargo            String
  situacao         String
  genero           String?
  idade            Int?
  instrucao        String?
  ocupacao         String?
  estadoCivil      String?
  raca             String?
  email            String?

  @@unique([ano, sequencial])
  @@index([ano, cargo])
  @@index([siglaPartido])
}

model TseResultadoSecao {
  id                  String @id @default(uuid())
  ano                 Int
  turno               Int
  zona                String
  secao               String
  cargo               String
  siglaPartido        String
  numeroCandidato     String
  sequencialCandidato String
  votos               Int

  @@index([ano, cargo])
  @@index([numeroCandidato, ano])
}

model TseDetalhesSecao {
  id                    String @id @default(uuid())
  ano                   Int
  turno                 Int
  zona                  String
  secao                 String
  cargo                 String
  aptos                 Int
  comparecimento        Int
  abstencoes            Int
  votosNominais         Int
  votosBrancos          Int
  votosNulos            Int
  proporcaoComparecimento Float?

  @@index([ano, zona])
}

model TsePerfilEleitorado {
  id           String @id @default(uuid())
  ano          Int
  turno        Int
  zona         String
  secao        String
  nome         String   // nome do local de votação
  tipo         String?
  endereco     String?
  bairro       String?
  latitude     Float?
  longitude    Float?
  eleitores    Int

  @@index([ano, bairro])
  @@index([bairro])
}

model TsePartido {
  id               String @id @default(uuid())
  ano              Int
  sigla            String
  nome             String
  cargo            String
  situacaoLegenda  String?
  nomeColigacao    String?

  @@index([ano, sigla])
}

model PopulacaoMunicipio {
  id          String @id @default(uuid())
  ano         Int
  grupoIdade  String
  sexo        String
  corRaca     String
  populacao   Int

  @@index([ano])
}
